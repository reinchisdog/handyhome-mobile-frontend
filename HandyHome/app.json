{
  "expo": {
    "name": "HandyHome",
    "description": "HandyHome puts home service at your fingertips — fast bookings, skilled pros, and no stress.",
    "slug": "HandyHome",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#E5EDF3",
    "icon": "./assets/images/icon.png",
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#58B7F3",
      "iosDisplayInForeground": true
    },
    "developmentClient": {
      "silentLaunch": true
    },
    "scheme": "handyhome",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "759b66b0-d109-4d05-9a4b-6158419712e6"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen", {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#58B7F3"
        }
      ], [
        "react-native-vision-camera", {
          "cameraPermissionText": "$(PRODUCT_NAME) needs access to your Camera."
        }
      ], [
        "expo-image-picker", {
          "photosPermission": "$(PRODUCT_NAME) needs access to your Photo Gallery."
        }
      ], [
        "expo-location", {
          "locationAlwaysAndWhenInUsePermission": "HandyHome needs your permission to access your location."
        }
      ]
    ],
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capstone.HandyHome",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#58B7F3"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.reinchisdog.HandyHome"
    },
    "experiments": {
      "typedRoutes": true
    }  
  }
}
